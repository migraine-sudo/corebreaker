{
  "manifest_version": 3,
  "name": "DNR regexSubstitution Scheme Bypass PoC",
  "version": "1.0",
  "description": "Tests whether DNR regexSubstitution can redirect subresource requests to data: URLs",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "*://testserver.example/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  }
}
